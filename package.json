{
  "name": "@vorionsys/car-cli",
  "version": "1.0.1",
  "description": "CLI for CAR (Categorical Agentic Registry) agent identity and governance operations",
  "keywords": [
    "car",
    "cli",
    "trust",
    "governance",
    "phase6",
    "categorical-agentic-registry",
    "vorion",
    "ai-governance",
    "agent",
    "trust-engine"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC",
  "homepage": "https://vorion.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/car-cli.git"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/car-cli/issues"
  },
  "type": "module",
  "bin": {
    "car": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vorionsys/car-client": "^1.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "changeset:release": "changeset publish"
  }
}
